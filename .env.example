# ============================================================================
# Agentic Ad Exchange Stack — environment variables
# ============================================================================
# Copy to .env.local and fill in. NEVER commit .env or .env.local.
# Generate a 32-byte entity secret with: pnpm --filter @ade/scripts generate:entity-secret
# ============================================================================

# --- Circle ------------------------------------------------------------------
CIRCLE_API_KEY=                # Circle sandbox/testnet key from console.circle.com
CIRCLE_ENTITY_SECRET=          # 32-byte hex, generated by scripts/generateEntitySecret
CIRCLE_ENVIRONMENT=testnet     # "testnet" | "mainnet" — mainnet forbidden until submission

# --- Arc (settlement chain) --------------------------------------------------
ARC_CHAIN_ID=5042002           # Arc testnet EVM chain ID — https://docs.arc.network/arc/references/network-information
ARC_RPC_URL=                   # https endpoint for Arc testnet

# --- Agent LLM ---------------------------------------------------------------
# Google Gemini API direct — the only LLM transport for the buyer + seller agents.
GEMINI_API_KEY=                # From aistudio.google.com or Cloud Console
GEMINI_MODEL=gemini-2.5-flash  # Direct Gemini model id

# --- Exchange server ---------------------------------------------------------
PORT=4021                      # Exchange server port
NODE_ENV=development
CORS_ALLOW_ORIGINS=http://localhost:5173  # Comma-separated allow-list; never "*"
BID_RATE_LIMIT_PER_MIN=120     # Per-wallet rate limit on POST /bid

# --- Scripts & demo wallets --------------------------------------------------
WALLET_SET_ID=                 # Populated by scripts/createWalletSet
BUYER_WALLET_ID=       # Populated by scripts/createWallets
BUYER_WALLET_ADDRESS=
SELLER_WALLET_ID=     # Populated by scripts/createWallets
SELLER_WALLET_ADDRESS=
MARKETPLACE_WALLET_ADDRESS=    # Seller DCW address for deposits/settlement
DEPOSIT_AMOUNT_USDC=0.10       # One-time Gateway deposit (matches nanopayments tutorial)
DEPOSIT_TIMEOUT_MS=1500000     # 25 min default — Circle testnet credits in 13–19 min
DEMO_LOAD_CYCLES=50            # Min 50 — hackathon ≥ 50 on-chain tx gate

# EOA address that receives x402 Gateway payouts (can be same as SELLER_WALLET_ADDRESS)
SELLER_EOA_ADDRESS=

# --- Agents ------------------------------------------------------------------
EXCHANGE_API_URL=http://localhost:4021  # Where agents reach the Exchange

# --- Multi-agent demo personas ----------------------------------------------
# Required for POST /demo/agent-run ("✨ Run Multi-Agent Auction (Gemini)").
# Each persona needs BOTH the Circle wallet id AND the on-chain address.
# Provision via scripts/createWallets, then paste the values below. A persona
# with only one of the two is silently skipped; if all three end up empty the
# demo route returns 503 demo_not_configured.
BUYER_LUXURYCO_WALLET_ID=
BUYER_LUXURYCO_WALLET_ADDRESS=
BUYER_GROWTHCO_WALLET_ID=
BUYER_GROWTHCO_WALLET_ADDRESS=
BUYER_RETAILCO_WALLET_ID=
BUYER_RETAILCO_WALLET_ADDRESS=

# --- UI ---------------------------------------------------------------------
# UI env vars MUST NOT contain secrets. VITE_*/NEXT_PUBLIC_* are bundle-visible.
VITE_API_BASE_URL=/api

# --- x402 Gateway & buyer EIP-3009 signer -----------------------------------
# Preserved from PR #1; server-side only, NEVER in ui/.env.example.
X402_NETWORK=eip155:5042002                 # CAIP-2 form of ARC_CHAIN_ID above — used by x402-batching facilitator URLs
CIRCLE_FACILITATOR_URL=https://gateway-api-testnet.circle.com
BUYER_CHAIN=arcTestnet                      # x402-batching chain key
BUYER_PRIVATE_KEY=  # Signs EIP-3009 authorizations (server-side only)
