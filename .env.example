# ============================================================================
# Agentic Ad Exchange Stack — environment variables
# ============================================================================
# Copy to .env.local and fill in. NEVER commit .env or .env.local.
# Generate a 32-byte entity secret with: pnpm --filter @ade/scripts generate:entity-secret
# ============================================================================

# --- Circle ------------------------------------------------------------------
CIRCLE_API_KEY=                # Circle sandbox/testnet key from console.circle.com
CIRCLE_ENTITY_SECRET=          # 32-byte hex, generated by scripts/generateEntitySecret
CIRCLE_ENVIRONMENT=testnet     # "testnet" | "mainnet" — mainnet forbidden until submission

# --- Arc (settlement chain) --------------------------------------------------
ARC_CHAIN_ID=421614            # Placeholder — verify against https://docs.arc.network at install
ARC_RPC_URL=                   # https endpoint for Arc testnet

# --- Google Gemini (agent LLM) -----------------------------------------------
GEMINI_API_KEY=                # From aistudio.google.com
GEMINI_MODEL=gemini-1.5-flash  # Agent default model

# --- Exchange server ---------------------------------------------------------
PORT=4021                      # Exchange server port
NODE_ENV=development
CORS_ALLOW_ORIGINS=http://localhost:5173  # Comma-separated allow-list; never "*"
BID_RATE_LIMIT_PER_MIN=120     # Per-wallet rate limit on POST /bid

# --- Scripts & demo wallets --------------------------------------------------
WALLET_SET_ID=                 # Populated by scripts/createWalletSet
BUYER_WALLET_ID=               # Populated by scripts/createWallets
SELLER_WALLET_ID=              # Populated by scripts/createWallets
MARKETPLACE_WALLET_ADDRESS=    # Seller DCW address for deposits/settlement
DEPOSIT_AMOUNT_USDC=0.10       # One-time Gateway deposit (matches nanopayments tutorial)

# --- Agents ------------------------------------------------------------------
EXCHANGE_API_URL=http://localhost:4021  # Where agents reach the Exchange

# --- UI ---------------------------------------------------------------------
# UI env vars MUST NOT contain secrets. VITE_*/NEXT_PUBLIC_* are bundle-visible.
VITE_API_BASE_URL=/api
