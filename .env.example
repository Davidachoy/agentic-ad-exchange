# ── Circle Platform ────────────────────────────────────────────
# Get your API key from https://console.circle.com
CIRCLE_API_KEY=TEST_API_KEY:your_api_key_here
CIRCLE_ENTITY_SECRET=your_entity_secret_here

# ── Developer-Controlled Wallets ───────────────────────────────
# Run `npm run script:initWallets` to generate these
BUYER_WALLET_ID=your_buyer_wallet_id
BUYER_WALLET_ADDRESS=0x_your_buyer_wallet_address
SELLER_WALLET_ID=your_seller_wallet_id
SELLER_WALLET_ADDRESS=0x_your_seller_wallet_address

# ── Exchange Server ─────────────────────────────────────────────
# EOA address that receives x402 Gateway payouts (can be same as SELLER_WALLET_ADDRESS)
SELLER_EOA_ADDRESS=0x_your_seller_eoa_address
PORT=3000

# ── Buyer Agent ─────────────────────────────────────────────────
# Private key for signing x402 Gateway EIP-3009 authorizations
BUYER_PRIVATE_KEY=0x_your_buyer_eoa_private_key
EXCHANGE_URL=http://localhost:3000
BUYER_CHAIN=arcTestnet

# ── Arc Testnet / x402 (defaults shown — override only if needed) ─
X402_NETWORK=eip155:5042002
CIRCLE_FACILITATOR_URL=https://gateway-api-testnet.circle.com

# ── Gemini (optional — for AI buyer agent) ───────────────────────
GEMINI_API_KEY=
