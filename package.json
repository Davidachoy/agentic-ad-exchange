{
  "name": "agentic-ad-exchange",
  "version": "0.1.0",
  "private": true,
  "description": "Agentic Ad Exchange Stack — autonomous ad auctions settled via Circle Nanopayments on Arc.",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.33.1+sha512.05ba3c1d5d1c18f68df06470d74055e62d41fc110a0c660db1b2dfb2785327f04cf0f68345d4609bc52089e7fa0343c31593b2f9594e2c5d5da426230acc9820",
  "scripts": {
    "dev": "concurrently -k -n server,ui -c blue,magenta \"pnpm --filter @ade/server dev\" \"pnpm --filter @ade/ui dev\"",
    "build": "pnpm -r --filter=!@ade/scripts build && pnpm --filter @ade/scripts build",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "audit": "pnpm audit",
    "precommit": "pnpm typecheck && pnpm lint && pnpm test"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "prettier": "^3.3.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^1.6.0"
  }
}
